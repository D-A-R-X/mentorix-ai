{
  "outputDirectory": "frontend",
  "framework": null,
  "rewrites": [
    { "source": "/admin", "destination": "/cronix-admin.html" },
    { "source": "/admin/", "destination": "/cronix-admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}